{
  "manifest_version": 3,
  "name": "Bookmark Nudge for X",
  "version": "2.0.0",
  "description": "Each time you open X, surfaces one of your saved bookmarks as a card at the top of your Home feed — so you actually read your bookmarks instead of hoarding them.",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://abs.twimg.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": { "128": "icons/icon128.png" }
}
